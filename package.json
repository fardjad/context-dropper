{
  "name": "context-dropper",
  "version": "0.3.0",
  "description": "CLI for iterating through a fixed list of files, tracking position, and tagging progress within an AI agent's session.",
  "author": {
    "name": "Fardjad Davari",
    "email": "public@fardjad.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fardjad/context-dropper"
  },
  "keywords": [
    "cli",
    "context",
    "llm",
    "ai",
    "opencode",
    "automation"
  ],
  "bin": {
    "context-dropper": "./dist/index.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "type": "module",
  "files": [
    "dist/index.js"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "clean": "rm -rf ./dist",
    "typecheck": "tsc --noEmit -p ./tsconfig.json",
    "test": "bun test ./src",
    "check": "biome check",
    "fix": "biome check --write",
    "prepack": "bun run build",
    "dev": "bun run ./src/index.ts",
    "build:standalone": "bun build ./src/index.ts --compile --outfile=./dist/context-dropper",
    "smoke:zsh-completion": "./hack/smoke-zsh-completion.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "^1.3.11",
    "husky": "^9.1.7",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@types/yargs": "^17.0.35",
    "jsonc-parser": "^3.3.1",
    "yargs": "^18.0.0"
  }
}
